# 环境变量配置示例
# 复制此文件为 .env 并填写真实值

# OpenAI 兼容接口（可替换为 DeepSeek、通义千问等）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1
MODEL_NAME=deepseek-chat

# 高德地图 MCP - 需要高德开放平台 Key
# 申请地址: https://lbs.amap.com/
AMAP_API_KEY=

# 飞常准 MCP API Key
# 申请地址: https://www.variflight.com/
VARIFLIGHT_API_KEY=

# 服务端口
PORT=8001
